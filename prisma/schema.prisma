generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id @default(uuid())
  createdAt        DateTime        @default(now())
  email            String          @unique
  username         String?         @unique
  password         String?
  name             String
  avatar           String?
  googleId         String?         @unique
  githubId         String?         @unique
  rating           Int             @default(1200)
  isVerified       Boolean         @default(false)
  sentRequests     FriendRequest[] @relation("FromUser")
  receivedRequests FriendRequest[] @relation("ToUser")
  friendOf         Friendship[]    @relation("FriendUsers")
  friendships      Friendship[]    @relation("UserFriends")
  blackGames       Game[]          @relation("BlackPlayer")
  whiteGames       Game[]          @relation("WhitePlayer")
  messages         Message[]       @relation("UserMessages")
  otps             Otp[]
  RefreshTokens    RefreshToken[]
}

model Otp {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Game {
  id        String         @id @default(uuid())
  createdAt DateTime       @default(now())
  endedAt   DateTime?
  whiteId   String?
  blackId   String?
  result    GameResult     @default(ONGOING)
  endReason GameEndReason?
  black     User?          @relation("BlackPlayer", fields: [blackId], references: [id])
  white     User?          @relation("WhitePlayer", fields: [whiteId], references: [id])
  moves     Move[]
}

model Move {
  id        Int    @id @default(autoincrement())
  gameId    String
  moveIndex Int
  fromRow   Int
  fromCol   Int
  toRow     Int
  toCol     Int
  game      Game   @relation(fields: [gameId], references: [id])
}

model FriendRequest {
  id        String              @id @default(uuid())
  fromId    String
  toId      String
  status    FriendRequestStatus @default(PENDING)
  createdAt DateTime            @default(now())
  from      User                @relation("FromUser", fields: [fromId], references: [id])
  to        User                @relation("ToUser", fields: [toId], references: [id])
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id])
  user      User     @relation("UserFriends", fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String?
  gameId     String?
  content    String
  createdAt  DateTime @default(now())
  sender     User     @relation("UserMessages", fields: [senderId], references: [id])
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum GameResult {
  ONGOING
  WHITE_WIN
  BLACK_WIN
  DRAW
}

enum GameEndReason {
  CHECKMATE
  STALEMATE
  TIMEOUT
  RESIGNATION
  ABANDONED
}
