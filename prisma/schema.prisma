// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
  moduleFormat  = "cjs"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  email     String   @unique
  password  String?
  name      String?
  avatar    String?

  googleId  String?  @unique
  githubId  String?  @unique

  whiteGames Game[]  @relation("WhitePlayer")
  blackGames Game[]  @relation("BlackPlayer")

  rating    Int      @default(1200)

  RefreshTokens RefreshToken[]

  sentRequests     FriendRequest[] @relation("FromUser")
  receivedRequests FriendRequest[] @relation("ToUser")
  friendships      Friendship[]    @relation("UserFriends")
  friendOf         Friendship[]    @relation("FriendUsers")
  messages         Message[]       @relation("UserMessages")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model Game {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  endedAt   DateTime?

  white     User?    @relation("WhitePlayer", fields: [whiteId], references: [id])
  whiteId   String?

  black     User?    @relation("BlackPlayer", fields: [blackId], references: [id])
  blackId   String?

  result    GameResult @default(ONGOING)

  moves     Move[]
}

model Move {
  id        Int    @id @default(autoincrement())
  gameId    String
  moveIndex Int

  fromRow   Int
  fromCol   Int
  toRow     Int
  toCol     Int

  game      Game   @relation(fields: [gameId], references: [id])
}

model FriendRequest {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  status    FriendRequestStatus @default(PENDING)
  createdAt DateTime @default(now())

  from      User     @relation("FromUser", fields: [fromId], references: [id])
  to        User     @relation("ToUser", fields: [toId], references: [id])
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user      User     @relation("UserFriends", fields: [userId], references: [id])
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  senderId  String
  receiverId String?
  gameId    String?
  content   String
  createdAt DateTime @default(now())

  sender    User     @relation("UserMessages", fields: [senderId], references: [id])
}

enum GameResult {
  ONGOING
  WHITE_WIN
  BLACK_WIN
  DRAW
}
