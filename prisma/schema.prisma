// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
  moduleFormat  = "cjs"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  email     String   @unique
  password  String?
  name      String?
  avatar    String?

  googleId  String?  @unique
  githubId  String?  @unique

  whiteGames Game[]  @relation("WhitePlayer")
  blackGames Game[]  @relation("BlackPlayer")

  rating    Int      @default(1200)

  RefreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime @default(dbgenerated("NOW() + INTERVAL '7 days'"))
}

model Game {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  endedAt   DateTime?

  white     User?    @relation("WhitePlayer", fields: [whiteId], references: [id])
  whiteId   String?

  black     User?    @relation("BlackPlayer", fields: [blackId], references: [id])
  blackId   String?

  result    GameResult @default(ONGOING)

  moves     Move[]
}

model Move {
  id        Int    @id @default(autoincrement())
  gameId    String
  moveIndex Int

  fromRow   Int
  fromCol   Int
  toRow     Int
  toCol     Int

  game      Game   @relation(fields: [gameId], references: [id])
}

enum GameResult {
  ONGOING
  WHITE_WIN
  BLACK_WIN
  DRAW
}
